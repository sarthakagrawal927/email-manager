---
import Layout from '@/layouts/Layout.astro';

// Kinetic landing — single static page.
//
// Static marketing landing for /. The full Next.js app (HomeClient)
// lives at /app. The Worker's ASSETS binding serves this `index.html`
// directly for anon GET /, bypassing OpenNext entirely so the LCP path
// is purely CDN-served HTML (no SSR, no React hydration, no Beasties
// pipeline, no cold-start). Copy is hand-written from agents.md so the
// pitch matches the product (Gmail triage, in-browser semantic search,
// IndexedDB privacy, RFC 8058 one-click unsubscribe, sender analytics).

const TITLE = 'Kinetic — Semantic Gmail search that runs in your browser';
const DESCRIPTION =
  'Gmail inbox workspace with local-first semantic search. Your emails and embeddings stay in your browser. Read-only Gmail scope, zero server storage.';
---

<Layout title={TITLE} description={DESCRIPTION}>
  <div class="page">
    <nav class="nav">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">K</span>
        <span>Kinetic</span>
      </a>
      <div class="nav-links">
        <a href="/about">About</a>
        <a href="/privacy">Privacy</a>
        <a href="/faq">FAQ</a>
        <a href="/app" class="nav-cta">Open app</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-pill">
        <span class="hero-pill-dot" aria-hidden="true"></span>
        Local-first Gmail workspace
      </div>
      <h1>
        Search your Gmail by meaning<br />
        <span class="accent">without uploading a single email.</span>
      </h1>
      <p class="lede">
        Kinetic is a Gmail workspace with semantic search that runs
        100% in your browser. Type what you remember — &ldquo;the lease
        renewal from last spring&rdquo; — and find it without keywords.
        Your inbox and embeddings stay in IndexedDB. Zero server-side
        email storage.
      </p>
      <div class="trust-row" aria-label="Trust signals">
        <span class="trust-chip">Read-only Gmail scope</span>
        <span class="trust-chip">0 bytes on our servers</span>
        <span class="trust-chip">IndexedDB + ONNX in-browser</span>
      </div>
      <div class="cta-row">
        <a class="btn btn-primary" href="/app">Connect Gmail and search</a>
      </div>
      <p class="fine">Semantic search, triage queues, and filter recipes — all client-side.</p>

      <div class="demo" aria-label="Semantic search preview">
        <div class="demo-frame">
          <div class="demo-bar">
            <span class="demo-dot" aria-hidden="true"></span>
            <span class="demo-dot" aria-hidden="true"></span>
            <span class="demo-dot" aria-hidden="true"></span>
            <span class="demo-url">kinetic / semantic search</span>
          </div>
          <div class="demo-body">
            <div class="demo-search">
              <span class="demo-search-icon" aria-hidden="true">&#9906;</span>
              <span class="demo-query">flight confirmation from last summer</span>
              <span class="demo-kbd">Enter</span>
            </div>
            <ul class="demo-results">
              <li>
                <span class="demo-rank">0.91</span>
                <div>
                  <strong>United Airlines</strong>
                  <span>Your trip to SFO — boarding pass for Jul 14</span>
                </div>
              </li>
              <li>
                <span class="demo-rank">0.87</span>
                <div>
                  <strong>Airbnb</strong>
                  <span>Reservation confirmed: Mission, San Francisco</span>
                </div>
              </li>
              <li>
                <span class="demo-rank">0.82</span>
                <div>
                  <strong>Google Calendar</strong>
                  <span>Flight UA 215 — Wed, Jul 14, 6:40 AM</span>
                </div>
              </li>
            </ul>
            <p class="demo-foot">
              Ranked by cosine similarity against embeddings generated
              locally with HuggingFace Transformers (ONNX).
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="features" aria-label="Features">
      <article class="card">
        <span class="card-tag">In-browser ML</span>
        <h3>Semantic search, locally</h3>
        <p>
          HuggingFace Transformers (ONNX) builds embeddings inside your
          browser and ranks results by cosine similarity. The model
          runs client-side; queries never leave your device.
        </p>
      </article>

      <article class="card">
        <span class="card-tag">Privacy by default</span>
        <h3>IndexedDB, not a server</h3>
        <p>
          Emails and embeddings persist in IndexedDB. API routes only
          proxy live Gmail calls — there is no server-side inbox copy
          and no third party in the loop.
        </p>
      </article>

      <article class="card">
        <span class="card-tag">RFC 8058</span>
        <h3>One-click unsubscribe</h3>
        <p>
          For senders that support it, Kinetic POSTs the standards
          one-click unsubscribe endpoint directly. For the rest, it
          opens the unsubscribe URL in a new tab.
        </p>
      </article>

      <article class="card">
        <span class="card-tag">Behavioral signal</span>
        <h3>Sender frequency analytics</h3>
        <p>
          See which senders and lists actually fill your inbox, ranked
          by volume. The same ranking powers Kinetic&rsquo;s suggested
          Gmail filter rules.
        </p>
      </article>
    </section>

    <section class="how" aria-label="How it works">
      <h2>Three steps. One afternoon.</h2>
      <ol>
        <li class="step">
          <span class="num">1</span>
          <h3>Connect Gmail</h3>
          <p>
            Sign in with Google. Kinetic requests read-only access — no
            compose, send, archive, or delete.
          </p>
        </li>
        <li class="step">
          <span class="num">2</span>
          <h3>Work your inbox</h3>
          <p>
            Triage by queue, search semantically in-browser, and review
            sender volume in one keyboard-driven cockpit.
          </p>
        </li>
        <li class="step">
          <span class="num">3</span>
          <h3>Export Gmail filters</h3>
          <p>
            Turn recurring noise into Gmail filter XML you import
            directly, so the rules apply even when Kinetic is closed.
          </p>
        </li>
      </ol>
    </section>

    <section class="closing">
      <h2>The only inbox tool that can&rsquo;t leak your email.</h2>
      <p>
        We physically cannot read your messages. Embeddings, search
        index, and message bodies live in your browser&rsquo;s
        IndexedDB. The server only proxies live Gmail calls.
      </p>
      <a class="btn btn-primary" href="/app">Connect Gmail and search</a>
    </section>

    <footer class="footer">
      <p class="footer-line">
        Built for people who want Gmail superpowers without giving up
        control. Vite, IndexedDB, ONNX Transformers, RFC 8058.
      </p>
      <div class="footer-links">
        <a href="/about">About</a><span class="footer-sep">·</span>
        <a href="/privacy">Privacy</a><span class="footer-sep">·</span>
        <a href="/faq">FAQ</a><span class="footer-sep">·</span>
        <a href="/app">Open app</a>
      </div>
      <div class="footer-copy">&copy; MMXXVI &middot; Kinetic</div>
    </footer>
  </div>
</Layout>
