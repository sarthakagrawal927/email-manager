{
  "name": "email-manager",
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack && node scripts/inline-critical-css.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "digest:verify": "pnpm dlx tsx scripts/verify-digest-fixture.mjs",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile",
    "patch:opennext": "node patches/opennext-cloudflare-externals.js",
    "cf:build": "pnpm patch:opennext && opennextjs-cloudflare build",
    "deploy": "pnpm cf:build && wrangler deploy"
  },
  "dependencies": {
    "@huggingface/transformers": "4.0.0",
    "@libsql/client": "0.17.3",
    "@saas-maker/feedback": "^0.2.1",
    "@saas-maker/sdk": "^0.3.1",
    "@saas-maker/testimonials": "^0.2.1",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "idb": "8.0.3",
    "next": "16.2.4",
    "posthog-js": "^1.372.1",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@eslint/js": "^9.39.4",
    "@opennextjs/cloudflare": "1.19.4",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "beasties": "^0.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "wrangler": "4.85.0"
  },
  "prettier": "@saas-maker/prettier-config"
}
