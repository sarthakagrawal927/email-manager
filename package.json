{
  "name": "email-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "patch": "node --input-type=module < patches/opennext-cloudflare-externals.js",
