{
  "name": "email-manager",
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,spa -c blue,green \"pnpm dev:api\" \"pnpm dev:spa\"",
    "dev:api": "wrangler dev",
    "dev:spa": "vite",
    "build": "vite build && pnpm --filter ./landing-astro build && node scripts/overlay-landing.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.worker.json",
    "lint": "eslint .",
    "digest:verify": "pnpm dlx tsx scripts/verify-digest-fixture.mjs",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile",
    "deploy": "pnpm build && wrangler deploy",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check ."
  },
  "dependencies": {
    "@huggingface/transformers": "4.0.0",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.15",
    "idb": "8.0.3",
    "posthog-js": "^1.372.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.6.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260424.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react-swc": "4.3.0",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.10",
    "wrangler": "4.85.0",
    "@biomejs/biome": "2.5.0",
    "globals": "17.5.0"
  }
}
