{
  "name": "email-manager",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,spa -c blue,green \"pnpm dev:api\" \"pnpm dev:spa\"",
    "predev": "node scripts/ensure-landing.mjs",
    "predev:spa": "node scripts/ensure-landing.mjs",
    "setup:dev": "node scripts/setup-dev.mjs",
    "dev:api": "wrangler dev --port 8787",
    "dev:spa": "vite",
    "build:landing": "pnpm --filter ./landing-astro build",
    "build": "vite build && pnpm build:landing && node scripts/overlay-landing.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.worker.json",
    "lint": "biome check .",
    "digest:verify": "pnpm dlx tsx scripts/verify-digest-fixture.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile",
    "deploy": "pnpm build && wrangler deploy",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:docs": "node scripts/check-docs.mjs",
    "foundry:evidence": "node scripts/foundry-evidence.mjs",
    "docs:dev": "pnpm --filter ./apps/docs-blume dev",
    "docs:build": "pnpm --filter ./apps/docs-blume build",
    "docs:preview": "pnpm --filter ./apps/docs-blume preview",
    "knip": "knip --no-exit-code --reporter symbols",
    "knip:strict": "knip --reporter symbols"
  },
  "dependencies": {
    "@huggingface/transformers": "4.0.0",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "better-auth": "1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.42.2",
    "hono": "4.12.15",
    "idb": "8.0.3",
    "lucide-react": "^1.23.0",
    "posthog-js": "^1.372.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.6.2",
    "tailwind-merge": "^3.6.0",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cloudflare/workers-types": "4.20260424.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react-swc": "4.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "9.2.1",
    "lightningcss": "^1.32.0",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "^4.1.9",
    "wrangler": "4.85.0",
    "knip": "^6.6.3"
  }
}
